spring:
  config:
    import:
      - optional:file:../config.yml
      - optional:file:./config.yml

  application:
    name: lifeledger

  servlet:
    multipart:
      enabled: true
      max-file-size: 20MB
      max-request-size: 25MB

  jpa:
    hibernate:
      ddl-auto: none
    show-sql: false
    open-in-view: false
    properties:
      hibernate:
        format_sql: false
        dialect: org.hibernate.dialect.PostgreSQLDialect
        jdbc:
          batch_size: 25
        order_inserts: true
        order_updates: true

  flyway:
    enabled: true
    locations: classpath:db/migration
    baseline-on-migrate: true
    validate-on-migrate: false
    out-of-order: false

  jackson:
    default-property-inclusion: non_null
    serialization:
      write-dates-as-timestamps: false
    deserialization:
      fail-on-unknown-properties: false

server:
  port: ${lifeledger.app.port:8080}
  servlet:
    context-path: ${lifeledger.app.context-path:/api}
  compression:
    enabled: true
    mime-types: application/json,application/xml,text/html,text/plain
    min-response-size: 1024

logging:
  level:
    com.lifeledger: ${lifeledger.logging.level.app:INFO}
    org.springframework.security: ${lifeledger.logging.level.security:WARN}
    org.flywaydb: INFO
  pattern:
    console: "%clr(%d{HH:mm:ss.SSS}){faint} %clr(%-5level) %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} : %msg%n"

lifeledger:
  cors:
    allowed-origins: ${LIFELEDGER_CORS_ORIGINS:http://localhost:4200}
  jwt:
    secret: ${LIFELEDGER_JWT_SECRET:CHANGE_ME_BASE64_256BIT_KEY}
    expiration-ms: 86400000
  database:
    host: ${LIFELEDGER_DB_HOST:localhost}
    port: ${LIFELEDGER_DB_PORT:5432}
    name: ${LIFELEDGER_DB_NAME:lifeledger}
    username: ${LIFELEDGER_DB_USERNAME:postgres}
    password: ${LIFELEDGER_DB_PASSWORD:CHANGE_ME}
    auto-create: true
    pool:
      minimum-idle: 2
      maximum-pool-size: 10

